### ============================================================================
### Step 1: Admin creates a Client App
### Stores: client_id, api_key, and vapid_public_key
### ============================================================================
POST {{baseUrl}}/admin/clients
Authorization: Bearer {{masterKey}}
Content-Type: application/json

{
  "name": "My Startup App"
}

> {%
    client.global.set("client_id", response.body.client_id);
    client.global.set("api_key", response.body.api_key);
    client.global.set("vapid_public_key", response.body.vapid_public_key);
%}

### ============================================================================
### Step 2: Composer Backend asks for a Frontend Token
### Stores: token into a global variable
### ============================================================================
POST {{baseUrl}}/auth/token
Authorization: Bearer {{api_key}}
Content-Type: application/json

{
  "user_id": "{{userId}}"
}

> {%
    client.global.set("token", response.body.token);
%}

### ============================================================================
### Step 3: Fetch the Web Agent (Service Worker)
### Run the push_test with a http server to test the subscription
### ============================================================================

